<mvc:View id="view" controllerName="Portfolio.controller.Portfolio"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.uxap"
	xmlns:m="sap.m"
	height="100%"
	width="100%">
	<ObjectPageLayout id="ObjectPageLayout" upperCaseAnchorBar="false">
		<headerTitle>
			<ObjectPageDynamicHeaderTitle id="headerSection">
				<expandedHeading>
					<m:Title id="title" text="Andol Abhilash" wrapping="true"/>
				</expandedHeading>
				<expandedContent>
					<m:Text id="text" text="SAP BTP Full Stack Developer"/>
				</expandedContent>
			</ObjectPageDynamicHeaderTitle>
		</headerTitle>
		<headerContent>
			<mvc:XMLView id="headerContentView" viewName="Portfolio.view.headerContent"/>
		</headerContent>
		<sections>
			<ObjectPageSection id="section1" titleUppercase="false" title="Section 1">
				<ObjectPageSubSection id="subsection1" titleUppercase="false" title="Projects">
					<mvc:XMLView id="XMLView" viewName="Portfolio.view.Project"/>
				</ObjectPageSubSection>
			</ObjectPageSection>
		</sections>
		<sections>
			<ObjectPageSection id="section2" titleUppercase="false" title="Section 2">
				<ObjectPageSubSection id="subsection2" titleUppercase="false" title="Skills">
					<mvc:XMLView id="XMLskillsView" viewName="Portfolio.view.Skills"/>
				</ObjectPageSubSection>
			</ObjectPageSection>
		</sections>
	</ObjectPageLayout>
</mvc:View>