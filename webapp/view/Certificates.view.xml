<mvc:View id="certificatesView" controllerName="Portfolio.controller.Certificates" xmlns:mvc="sap.ui.core.mvc" xmlns:m="sap.m">
    <m:FlexBox id="certificatesFlexBox" class="sapUiTinyMarginBegin sapUiTinyMarginTop" items="{certificates>/}" wrap="Wrap">
        <m:items>
            <m:GenericTile id="certificateBox" frameType="TwoByOne" headerImage="images/sap-logo.png" header="{certificates>name}"
                class="sapUiSmallMarginEnd sapUiSmallMarginBottom customCertificateBg">
                <m:TileContent id="certificateTileContent">
                    <m:VBox id="certificateVBox" fitContainer="true" class="sapUiSmallMargin sapUiSmallMarginTop">
                        <m:items>
                            <m:Text id="certificateDate" text="{certificates>date}" />
                            <m:Button id="certificateButton" text="View Certificate" press=".onViewCertificatePress" />
                        </m:items>
                    </m:VBox>
                </m:TileContent>
            </m:GenericTile>
        </m:items>
    </m:FlexBox>
</mvc:View>