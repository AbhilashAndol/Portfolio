<mvc:View id="headerView" xmlns:mvc="sap.ui.core.mvc" xmlns:m="sap.m" xmlns:layout="sap.ui.layout" controllerName="Portfolio.controller.Header" class = "myCustomHeaderBg">
    <!-- Main wrapper container with Standard Theme Background and Padding -->
    <m:FlexBox id="gvMainContainer" wrap="Wrap" class="sapUiSmallMarginTop sapUiTileBackground sapUiContentPadding" width="100%">
        
        <!-- Inner responsive container -->
        <m:FlexBox id="gvResponsiveWrapper" wrap="Wrap" class="sapUiSmallMarginBeginEnd" width="100%">
            
            <!-- ROW 1: Header Top Row (Avatar + Info on Left, Resume on Far Right) -->
            <m:FlexBox id="ghRowHeaderTop" direction="Row" wrap="Wrap" alignItems="Center" justifyContent="SpaceBetween" width="100%" class="sapUiSmallMarginBottom">
                
                <!-- Left side group: Combined Avatar and Titles -->
                <m:FlexBox id="ghGroupProfileDetails" direction="Row" wrap="Wrap" alignItems="Center">
                    <m:Avatar id="avProfilePicture" src="{headerContent>/avatar}" displaySize="XL" class="sapUiTinyMarginEnd sapUiTinyMarginRight"/>
                    
                    <m:FlexBox id="gvNameAndTitle" direction="Column" class="sapUiSmallMarginBeginEnd">
                        <m:Text id="txtProfileName" text="{headerContent>/name}" wrapping="true" class="headerText"/>
                        <m:Text id="txtProfileTitle" text="{headerContent>/title}" wrapping="true"/>
                    </m:FlexBox>
                </m:FlexBox>
                
            </m:FlexBox>
            
            <!-- ROW 2 & 3: Beneath the top row -->
            <layout:VerticalLayout id="vlProfileBody" class="sapUiSmallMarginBeginEnd" width="100%">
                
                <!-- Short Bio / About Section -->
                <m:Text id="txtAboutMe" text="{headerContent>/about}" wrapping="true" width="100%" class="sapUiSmallMarginBottom"/>

                <!-- ROW 3: Standardized Contact Info Ribbon -->
                <m:FlexBox id="ghRowContactRibbon" direction="Row" wrap="Wrap" alignItems="Center" justifyContent="Start" width="100%">
                    <m:Text id="txtContactEmail" text="Email: {headerContent>/email}" wrapping="true" class="sapUiMediumMarginEnd sapUiSmallMarginBottom"/>
                    <m:Text id="txtContactPhone" text="Phone: {headerContent>/phone}" wrapping="true" class="sapUiMediumMarginEnd sapUiSmallMarginBottom"/>
                    <m:Button id="btnLinkedInLink" icon="images/linkedin.png" press="onLinkedInPress" class="sapUiMediumMarginEnd sapUiSmallMarginBottom"/>
                    <m:Button id="btnBlog" icon="sap-icon://notes" text = "Blog" press = "onBlogInPress" class="sapUiMediumMarginEnd sapUiSmallMarginBottom"/>
                    <m:Button id="btnDownloadResume" text="Resume" icon="sap-icon://document-text" press="onResumePress" class="sapUiSmallMarginBottom"/>
                </m:FlexBox>
                
            </layout:VerticalLayout>
        </m:FlexBox>
        
    </m:FlexBox>
</mvc:View>