<mvc:View id="projectView" controllerName="Portfolio.controller.Project" xmlns:mvc="sap.ui.core.mvc" xmlns:m="sap.m">
    <m:FlexBox id="projectVBox" class="sapUiTinyMarginBegin sapUiTinyMarginTop" items="{projects>/}" wrap="Wrap">
        <m:items>
            <m:GenericTile id="projectTile"
                header="{projects>name}" 
                subheader="{projects>description}" 
                frameType="TwoByHalf" 
                press=".press"
                class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <m:TileContent id="tileContent"/>
            </m:GenericTile>
        </m:items>
    </m:FlexBox>
</mvc:View>