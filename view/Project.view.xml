<mvc:View id="projectView" controllerName="Portfolio.controller.Project" xmlns:mvc="sap.ui.core.mvc" xmlns:m="sap.m">
    <m:FlexBox id="projectVBox" class="sapUiTinyMarginBegin sapUiTinyMarginTop" items="{projects>/}" wrap="Wrap" justifyContent="Center">
        <m:items>
            <m:GenericTile id="projectTile"
                header="{projects>name}" 
                frameType="TwoByOne"
                press=".onProjectInPress"
                class="sapUiSmallMarginEnd sapUiSmallMarginBottom customTileBg">
                <m:TileContent id="tileContent" class="sapUiNoMarginTop sapUiContentPadding">
                    
                    <!-- 1. We wrap everything inside a VBox so the skills stay safely under the text -->
                    <m:VBox id="projectVBox1" height="100%">
                        
                        <!-- Top part: Your description -->
                        <m:Text id="projectText" text="{projects>description}" wrapping="true" maxLines="3" class="sapUiTinyMarginBottom" />
                        <m:HBox id="skillsHBox" wrap="Wrap" class="sapUiTinyMarginTop" items="{projects>skills}">
                            <m:Button id="skillButton" text="{projects>}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom " />
                        </m:HBox>
                        
                    </m:VBox>
                    
                </m:TileContent>
            </m:GenericTile>
        </m:items>
    </m:FlexBox>
</mvc:View>